---
// Hero 우상단 액센트: 정적 SVG sparkle.
// public/lottie/hero-accent.lottie 파일을 추가하면 LottieView로 교체 가능.
---

<section class="relative overflow-hidden bg-white">
  <div class="container-content grid items-center gap-14 py-20 md:py-28 lg:grid-cols-12 lg:gap-16">
    {/* 좌측: 카피 */}
    <div class="lg:col-span-7" data-reveal>
      <span class="eyebrow">
        <span class="h-1.5 w-1.5 rounded-full bg-primary-500"></span>
        Hey, Voca! · iOS · Android
      </span>

      <h1 class="mt-6 text-balance font-extrabold tracking-tight text-ink text-[44px] leading-[1.08] md:text-[64px] lg:text-display-2xl">
        접속만 하세요.<br />
        나머진 <span class="text-primary-500">헤이보카</span>가<br class="hidden md:block" />
        알아서 합니다.
      </h1>

      <p class="mt-7 max-w-prose text-body-lg text-sub text-pretty">
        어떤 단어를 언제 다시 봐야 할지, 헤이보카가 대신 챙겨드립니다.
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-3">
        <a href="#download" class="btn-primary">
          앱 받기
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
        <a href="#demo" class="btn-ghost">
          둘러보기
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 5v14M6 13l6 6 6-6" />
          </svg>
        </a>
      </div>

      <dl class="mt-12 flex flex-wrap items-center gap-x-8 gap-y-3 text-body-sm text-mute">
        <div class="flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5" /></svg>
          무료로 시작
        </div>
        <div class="flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5" /></svg>
          광고 없음
        </div>
        <div class="flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5" /></svg>
          iOS · Android 자동 동기화
        </div>
      </dl>
    </div>

    {/* 우측: iPhone frame + 마스코트 */}
    <div class="lg:col-span-5" data-reveal>
      <div class="relative mx-auto w-full max-w-[440px]" id="hero-stage">
        {/* 우상단 SVG sparkle 액센트 */}
        <svg
          aria-hidden="true"
          viewBox="0 0 80 80"
          class="pointer-events-none absolute -top-2 right-0 z-10 h-16 w-16 text-primary-500 md:-top-4 md:h-20 md:w-20"
        >
          <g class="origin-center animate-[pulseRing_2.4s_ease-in-out_infinite]">
            <path d="M40 8 L44 36 L72 40 L44 44 L40 72 L36 44 L8 40 L36 36 Z" fill="currentColor" opacity="0.85" />
          </g>
          <circle cx="68" cy="14" r="2.5" fill="currentColor" opacity="0.6" />
          <circle cx="14" cy="64" r="2" fill="currentColor" opacity="0.5" />
        </svg>

        {/* iPhone frame mockup — 실서비스 StudyMain.jsx 디자인 100% 일치 (75% 스케일) */}
        <div class="relative mx-auto aspect-[9/19] w-[280px] md:w-[300px]">
          <div class="absolute inset-0 rounded-[42px] bg-ink p-[6px] shadow-card">
            <div class="relative h-full w-full overflow-hidden rounded-[36px] bg-white">
              {/* Dynamic island */}
              <div class="absolute left-1/2 top-2 z-10 h-[22px] w-[88px] -translate-x-1/2 rounded-full bg-ink"></div>

              <div class="flex h-full flex-col">
                {/* status bar */}
                <div class="flex items-center justify-between px-6 pt-2 text-[10px] font-semibold text-ink">
                  <span>9:41</span>
                  <span>●●●●</span>
                </div>

                {/* StudyHeader (뒤로가기 + 설정) — 비율 맞춰 단순화 */}
                <div class="flex items-center justify-between px-[15px] pt-6">
                  <svg width="14" height="14" viewBox="0 0 256 256" fill="#0A0A0A" aria-hidden="true">
                    <path d="M165.66 202.34a8 8 0 0 1-11.32 11.32l-80-80a8 8 0 0 1 0-11.32l80-80a8 8 0 0 1 11.32 11.32L91.31 128Z"/>
                  </svg>
                  <svg width="14" height="14" viewBox="0 0 256 256" fill="#0A0A0A" aria-hidden="true">
                    <path d="M128 80a48 48 0 1 0 48 48 48.05 48.05 0 0 0-48-48Zm0 80a32 32 0 1 1 32-32 32 32 0 0 1-32 32Zm88.71-44.45-23.62-9.4a96.16 96.16 0 0 0-4-9.65l5.26-25.39a8 8 0 0 0-2.15-7.49l-20.84-20.84a8 8 0 0 0-7.49-2.15l-25.39 5.26a96.16 96.16 0 0 0-9.65-4l-9.4-23.62a8 8 0 0 0-7.43-5h-29.49a8 8 0 0 0-7.43 5l-9.4 23.62a96.16 96.16 0 0 0-9.65 4L40.65 30.63a8 8 0 0 0-7.49 2.15L12.32 53.62a8 8 0 0 0-2.15 7.49l5.26 25.39a96.16 96.16 0 0 0-4 9.65l-23.62 9.4Z"/>
                  </svg>
                </div>

                {/* 프로그레스 바 — 실서비스: h-[16px] bg-primary-main-100 → bg-primary-main-600 */}
                <div class="mt-[5px] px-[15px]">
                  <div class="relative h-[12px] w-full overflow-hidden rounded-[50px] bg-primary-100">
                    <div class="h-full rounded-[50px] bg-primary-500" style="width: 85.7%;"></div>
                    <span class="absolute right-[8px] top-1/2 -translate-y-1/2 text-[7px] font-semibold text-[#7b7b7b]" style="letter-spacing: -0.2px;">12/14</span>
                  </div>
                </div>

                {/* 카드 영역 — 실서비스: bg-layout-gray-50 #F5F5F5, rounded-[12px], p-[20px], gap-[25px] */}
                <div class="mt-[12px] mx-[15px] flex-1 overflow-hidden rounded-[12px] bg-[#F5F5F5] p-[15px]">
                  <div class="flex flex-col gap-[18px]">
                    {/* 상단: 암기 상태 뱃지 + 단어 */}
                    <div class="flex flex-col gap-[4px]">
                      {/* MemorizationStatus 뱃지 — 단기암기 (Leaf), 실서비스 색상 그대로 */}
                      <span class="inline-flex w-fit items-center gap-[3px] py-[2px] px-[4px] rounded-[50px] border text-[7px] font-semibold"
                            style="color: #77CE4F; border-color: #77CE4F; background-color: #F2FFEB;">
                        <svg width="8" height="8" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
                          <path d="M223.5 32h-72A104.6 104.6 0 0 0 47 136.5a103.66 103.66 0 0 0 21.5 63.27L43.05 225.21a8 8 0 0 0 11.32 11.32l25.41-25.41A103.66 103.66 0 0 0 143 232.55a104.59 104.59 0 0 0 104.5-104.5v-88a8 8 0 0 0-8-8.05Z"/>
                        </svg>
                        단기암기
                      </span>

                      {/* 단어 + 스피커 */}
                      <div class="flex items-start justify-between gap-[4px]">
                        <span class="text-[18px] font-bold leading-[22px] text-ink">serendipity</span>
                        <button type="button" class="py-[2px]" aria-label="serendipity 발음 듣기">
                          <svg width="12" height="12" viewBox="0 0 256 256" fill="#C5C5C5" aria-hidden="true">
                            <path d="M155.51 24.81a8 8 0 0 0-8.42.88L77.25 80H32a16 16 0 0 0-16 16v64a16 16 0 0 0 16 16h45.25l69.84 54.31A8 8 0 0 0 160 224V32a8 8 0 0 0-4.49-7.19Z"/>
                          </svg>
                        </button>
                      </div>
                    </div>

                    {/* 의미 — 실서비스: text-[13px] font-[400] (75% 스케일 → 10px) */}
                    <div class="flex flex-col gap-[3px]">
                      <div class="flex items-center justify-between gap-[6px]">
                        <span class="flex-1 text-[10px] font-normal text-[#5C5C5C]">행운</span>
                        <svg width="12" height="12" viewBox="0 0 256 256" fill="#C5C5C5" aria-hidden="true">
                          <path d="M155.51 24.81a8 8 0 0 0-8.42.88L77.25 80H32a16 16 0 0 0-16 16v64a16 16 0 0 0 16 16h45.25l69.84 54.31A8 8 0 0 0 160 224V32a8 8 0 0 0-4.49-7.19Z"/>
                        </svg>
                      </div>
                      <div class="flex items-center justify-between gap-[6px]">
                        <span class="flex-1 text-[10px] font-normal text-[#5C5C5C]">뜻밖의 발견</span>
                        <svg width="12" height="12" viewBox="0 0 256 256" fill="#C5C5C5" aria-hidden="true">
                          <path d="M155.51 24.81a8 8 0 0 0-8.42.88L77.25 80H32a16 16 0 0 0-16 16v64a16 16 0 0 0 16 16h45.25l69.84 54.31A8 8 0 0 0 160 224V32a8 8 0 0 0-4.49-7.19Z"/>
                        </svg>
                      </div>
                    </div>

                    {/* 예문 영역 — 실서비스: 라벨 text-[14px] font-[700], 본문 text-[14px] font-[400] */}
                    <div class="flex flex-col gap-[6px]">
                      <p class="text-[11px] font-bold text-ink">예문</p>
                      <div class="flex items-start justify-between gap-[4px]">
                        <span class="flex-1 text-[11px] font-normal text-ink leading-[14px]">Their meeting was a result of pure serendipity.</span>
                        <svg width="12" height="12" viewBox="0 0 256 256" fill="#C5C5C5" class="mt-[1px] shrink-0" aria-hidden="true">
                          <path d="M155.51 24.81a8 8 0 0 0-8.42.88L77.25 80H32a16 16 0 0 0-16 16v64a16 16 0 0 0 16 16h45.25l69.84 54.31A8 8 0 0 0 160 224V32a8 8 0 0 0-4.49-7.19Z"/>
                        </svg>
                      </div>
                      <span class="text-[10px] font-normal text-[#7b7b7b] leading-[13px]">그들의 만남은 순전한 우연한 행운의 결과였다.</span>
                    </div>
                  </div>
                </div>

                {/* 하단 3버튼 — 실서비스: h-[45px] rounded-[8px] text-[16px] font-[700] (75%: ~34px, 12px) */}
                <div class="flex gap-[6px] px-[15px] pt-[15px] pb-[15px]">
                  <div class="flex h-[34px] flex-1 items-center justify-center rounded-[8px] bg-[#F0F0F0] text-[12px] font-bold text-[#C5C5C5]">이전</div>
                  <div class="flex h-[34px] flex-1 items-center justify-center rounded-[8px] bg-[#C5C5C5] text-[12px] font-bold text-white">재생</div>
                  <div class="flex h-[34px] flex-1 items-center justify-center rounded-[8px] bg-[#C5C5C5] text-[12px] font-bold text-white">다음</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* 마스코트 */}
        <img
          src="/images/HeyCharacter.png"
          alt=""
          width="220"
          height="330"
          class="pointer-events-none absolute -right-6 -bottom-4 hidden h-auto w-[180px] animate-float-y select-none md:block lg:-right-10 lg:w-[200px]"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>
