---
// Hero 우상단 액센트: 정적 SVG sparkle.
// public/lottie/hero-accent.lottie 파일을 추가하면 LottieView로 교체 가능.
---

<section class="relative overflow-hidden bg-white">
  <div class="container-content grid items-center gap-14 py-20 md:py-28 lg:grid-cols-12 lg:gap-16">
    {/* 좌측: 카피 */}
    <div class="lg:col-span-7" data-reveal>
      <span class="eyebrow">
        <span class="h-1.5 w-1.5 rounded-full bg-primary-500"></span>
        Hey, Voca! · iOS · Android · Web
      </span>

      <h1 class="mt-6 text-balance font-extrabold tracking-tight text-ink text-[44px] leading-[1.08] md:text-[64px] lg:text-display-2xl">
        그냥 외우세요.<br />
        나머진 <span class="text-primary-500">헤이보카</span>가<br class="hidden md:block" />
        알아서 합니다.
      </h1>

      <p class="mt-7 max-w-prose text-body-lg text-sub text-pretty">
        언제 다시 봐야 할지, 어떤 단어가 약점인지<br class="hidden md:block" />
        — 데이터가 대신 챙겨드립니다.
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-3">
        <a href="#download" class="btn-primary">
          앱 받기
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6" />
          </svg>
        </a>
        <a href="#demo" class="btn-ghost">
          둘러보기
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 5v14M6 13l6 6 6-6" />
          </svg>
        </a>
      </div>

      <dl class="mt-12 flex flex-wrap items-center gap-x-8 gap-y-3 text-body-sm text-mute">
        <div class="flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5" /></svg>
          무료로 시작
        </div>
        <div class="flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5" /></svg>
          광고 없음
        </div>
        <div class="flex items-center gap-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6L9 17l-5-5" /></svg>
          3개 기기 동시 동기화
        </div>
      </dl>
    </div>

    {/* 우측: iPhone frame + 마스코트 */}
    <div class="lg:col-span-5" data-reveal>
      <div class="relative mx-auto w-full max-w-[440px]" id="hero-stage">
        {/* 우상단 SVG sparkle 액센트 */}
        <svg
          aria-hidden="true"
          viewBox="0 0 80 80"
          class="pointer-events-none absolute -top-2 right-0 z-10 h-16 w-16 text-primary-500 md:-top-4 md:h-20 md:w-20"
        >
          <g class="origin-center animate-[pulseRing_2.4s_ease-in-out_infinite]">
            <path d="M40 8 L44 36 L72 40 L44 44 L40 72 L36 44 L8 40 L36 36 Z" fill="currentColor" opacity="0.85" />
          </g>
          <circle cx="68" cy="14" r="2.5" fill="currentColor" opacity="0.6" />
          <circle cx="14" cy="64" r="2" fill="currentColor" opacity="0.5" />
        </svg>

        {/* iPhone frame mockup */}
        <div class="relative mx-auto aspect-[9/19] w-[280px] md:w-[300px]">
          {/* phone body */}
          <div class="absolute inset-0 rounded-[42px] bg-ink p-[6px] shadow-card">
            <div class="relative h-full w-full overflow-hidden rounded-[36px] bg-white">
              {/* Dynamic island */}
              <div class="absolute left-1/2 top-2 z-10 h-[22px] w-[88px] -translate-x-1/2 rounded-full bg-ink"></div>

              {/* Screen content: 미리보기 단어 카드 */}
              <div class="flex h-full flex-col">
                {/* status bar 가짜 */}
                <div class="flex items-center justify-between px-6 pt-2 text-[10px] font-semibold text-ink">
                  <span>9:41</span>
                  <span>●●●●</span>
                </div>

                {/* top bar */}
                <div class="flex items-center justify-between px-5 pt-6">
                  <span class="text-[11px] font-semibold text-mute">오늘의 학습</span>
                  <span class="rounded-full bg-surface px-2 py-0.5 text-[10px] font-semibold text-sub">12 / 30</span>
                </div>

                {/* card */}
                <div class="flex flex-1 flex-col items-center justify-center px-5 pb-6">
                  <span class="inline-flex items-center gap-1 rounded-full bg-primary-100 px-2.5 py-0.5 text-[10px] font-semibold text-primary-700">
                    다시 만난 단어
                  </span>
                  <p class="mt-4 font-mono text-2xl font-bold tracking-tight text-ink">serendipity</p>
                  <p class="mt-1 text-[11px] text-mute">/ˌserənˈdɪpəti/</p>
                  <div class="mt-5 w-full rounded-xl bg-surface px-3 py-3 text-center text-[12px] text-sub">
                    뜻밖의 행운, 우연한 발견
                  </div>
                  <div class="mt-6 flex w-full items-center justify-around">
                    <button class="flex h-9 w-20 items-center justify-center rounded-full bg-surface text-[11px] font-semibold text-sub" aria-hidden="true">모르겠음</button>
                    <button class="flex h-9 w-20 items-center justify-center rounded-full bg-primary-500 text-[11px] font-semibold text-white" aria-hidden="true">완벽</button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* 마스코트 */}
        <img
          src="/images/HeyCharacter.png"
          alt=""
          width="220"
          height="330"
          class="pointer-events-none absolute -right-6 -bottom-4 hidden h-auto w-[180px] animate-float-y select-none md:block lg:-right-10 lg:w-[200px]"
          loading="eager"
          decoding="async"
        />
      </div>
    </div>
  </div>
</section>
