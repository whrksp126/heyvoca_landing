---
// 외부 단어장 6종 — 순수 Astro 정적 그리드.
// 각 카드는 인라인 SVG 로고 + 형식명 + 한 줄 설명.

type FormatItem = {
  name: string;
  desc: string;
  // 인라인 SVG markup (set:html 으로 주입). image 가 있으면 우선 사용.
  icon?: string;
  image?: string;
};

const formats: FormatItem[] = [
  {
    name: 'Excel',
    desc: '.xlsx 시트 그대로',
    icon: `
      <svg viewBox="0 0 48 48" width="44" height="44" aria-hidden="true">
        <rect x="6" y="6" width="36" height="36" rx="4" fill="#107C41"/>
        <rect x="6" y="6" width="36" height="9" rx="4" fill="#0B5A30"/>
        <path d="M18 18 L24 24 L18 30 M30 18 L24 24 L30 30" fill="none" stroke="#FFFFFF" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/>
        <text x="24" y="13.6" text-anchor="middle" fill="#FFFFFF" font-family="system-ui, sans-serif" font-size="6" font-weight="700">XLSX</text>
      </svg>
    `,
  },
  {
    name: 'CSV',
    desc: '쉼표 구분 텍스트',
    icon: `
      <svg viewBox="0 0 48 48" width="44" height="44" aria-hidden="true">
        <rect x="6" y="6" width="36" height="36" rx="4" fill="#6B7280"/>
        <rect x="6" y="6" width="36" height="9" rx="4" fill="#4B5563"/>
        <text x="24" y="13.6" text-anchor="middle" fill="#FFFFFF" font-family="system-ui, sans-serif" font-size="6" font-weight="700">CSV</text>
        <text x="24" y="32" text-anchor="middle" fill="#FFFFFF" font-family="ui-monospace, monospace" font-size="7" font-weight="600">a,b,c</text>
      </svg>
    `,
  },
  {
    name: 'Quizlet',
    desc: '카드 세트 임포트',
    image: '/images/logos/quizlet.svg',
  },
  {
    name: 'Anki',
    desc: '.apkg 덱 가져오기',
    image: '/images/logos/anki.svg',
  },
  {
    name: 'Google Sheets',
    desc: '구글 시트 링크 연동',
    icon: `
      <svg viewBox="0 0 48 48" width="44" height="44" aria-hidden="true">
        <path d="M14 6 H30 L40 16 V40 a2 2 0 0 1 -2 2 H14 a2 2 0 0 1 -2 -2 V8 a2 2 0 0 1 2 -2 Z" fill="#0F9D58"/>
        <path d="M30 6 V14 a2 2 0 0 0 2 2 H40 Z" fill="#57BB8A"/>
        <rect x="17" y="22" width="14" height="2" fill="#FFFFFF"/>
        <rect x="17" y="26" width="14" height="2" fill="#FFFFFF"/>
        <rect x="17" y="30" width="14" height="2" fill="#FFFFFF"/>
        <rect x="22" y="20" width="2" height="14" fill="#FFFFFF"/>
      </svg>
    `,
  },
  {
    name: 'PDF',
    desc: '문서에서 단어 추출',
    icon: `
      <svg viewBox="0 0 48 48" width="44" height="44" aria-hidden="true">
        <path d="M14 6 H30 L40 16 V40 a2 2 0 0 1 -2 2 H14 a2 2 0 0 1 -2 -2 V8 a2 2 0 0 1 2 -2 Z" fill="#E53935"/>
        <path d="M30 6 V14 a2 2 0 0 0 2 2 H40 Z" fill="#FFCDD2"/>
        <text x="24" y="33" text-anchor="middle" fill="#FFFFFF" font-family="system-ui, sans-serif" font-size="8" font-weight="800">PDF</text>
      </svg>
    `,
  },
];
---

<section class="section bg-surface hairline-t hairline-b" aria-labelledby="import-h2">
  <div class="container-content">
    <div class="max-w-3xl" data-reveal>
      <span class="eyebrow">
        <span class="h-1.5 w-1.5 rounded-full bg-primary-500"></span>
        외부 단어장
      </span>
      <h2
        id="import-h2"
        class="mt-6 text-balance text-[36px] font-bold leading-[1.12] tracking-tight text-ink md:text-display-lg lg:text-display-xl"
      >
        이미 만들어둔 단어장이 있나요?
      </h2>
      <p class="mt-6 max-w-prose text-body-lg text-sub text-pretty">
        Excel · CSV · Quizlet · Anki · Google Sheets · PDF — 어떤 형식이든 그대로 가져옵니다.
        헤이보카로 옮기는 데 5초.
      </p>
    </div>

    <ul
      class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3"
      data-reveal-stagger
      data-stagger-ms="60"
    >
      {formats.map((f) => (
        <li
          class="card group flex items-center gap-4 p-5 transition-[transform,box-shadow] duration-200 hover:-translate-y-0.5 hover:shadow-card"
        >
          {f.image ? (
            <img
              src={f.image}
              alt={`${f.name} 로고`}
              width="44"
              height="44"
              class="shrink-0 rounded-[10px] object-contain"
              loading="lazy"
              decoding="async"
            />
          ) : (
            <span class="shrink-0" set:html={f.icon} />
          )}
          <div class="flex min-w-0 flex-col">
            <p class="text-body font-semibold text-ink">{f.name}</p>
            <p class="text-body-sm text-sub">{f.desc}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
