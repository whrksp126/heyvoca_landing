---
const categories = [
  'TOEIC',
  '수능',
  '비즈니스 영어',
  '일상 회화',
  'IELTS',
  '독서·뉴스',
  'OPIC',
  '편입·공무원',
];
const items = [...categories, ...categories]; // marquee 무한 루프용
---

<section class="hairline-t hairline-b bg-surface py-10 md:py-12" aria-label="지원 영역">
  <div class="container-content flex flex-col items-center gap-6 text-center">
    <p class="text-caption font-medium uppercase tracking-[0.18em] text-mute">
      어떤 영어든
    </p>
    <div class="mask-fade-x w-full overflow-hidden">
      <ul
        class="flex w-max items-center gap-12 whitespace-nowrap animate-marquee"
        aria-hidden="true"
      >
        {items.map((c) => (
          <li class="text-heading-md font-semibold text-sub md:text-2xl">{c}</li>
        ))}
      </ul>
    </div>
  </div>
</section>
