---
// 5단계 암기 상태 쇼케이스 — React island 마운트만 담당.
// MemoryStatesDemo.tsx는 Agent 2가 작성/덮어쓰는 컴포넌트.
import MemoryStatesDemo from './demo/MemoryStatesDemo';

// 5단계 dot legend (Solution 카드와 토큰 통일)
const legend = [
  { name: '미학습', color: '#9D835A' },
  { name: '단기암기', color: '#77CE4F' },
  { name: '중기암기', color: '#38CE38' },
  { name: '장기암기', color: '#F68300' },
  { name: '복습 지연', color: '#F26A6A' },
];
---

<section class="section bg-white" aria-labelledby="memory-states-h2">
  <div class="container-content">
    <div class="max-w-3xl" data-reveal>
      <span class="eyebrow">
        <span class="h-1.5 w-1.5 rounded-full bg-primary-500"></span>
        암기 상태 관리
      </span>
      <h2
        id="memory-states-h2"
        class="mt-6 text-balance text-[36px] font-bold leading-[1.12] tracking-tight text-ink md:text-display-lg lg:text-display-xl"
      >
        같은 단어도, 시간이 지나면 다르게 보입니다.
      </h2>
      <p class="mt-6 max-w-prose text-body-lg text-sub text-pretty">
        미학습 → 단기암기 → 중기암기 → 장기암기. 복습 시점을 놓치면 복습 지연 상태로 별도 관리.
        단어마다 지금 어디쯤에 있는지, 다음에 언제 보여줘야 하는지 헤이보카가 정확히 알고 있습니다.
      </p>
    </div>

    <div class="mt-14" data-reveal>
      <MemoryStatesDemo client:visible />
    </div>

    {/* 5단계 색상 dot legend */}
    <ul
      class="mt-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-3"
      data-reveal
      aria-label="암기 상태 범례"
    >
      {legend.map((l) => (
        <li class="inline-flex items-center gap-2 text-body-sm text-sub">
          <span
            class="inline-block h-2.5 w-2.5 rounded-full"
            style={`background-color: ${l.color};`}
            aria-hidden="true"
          ></span>
          {l.name}
        </li>
      ))}
    </ul>
  </div>
</section>
