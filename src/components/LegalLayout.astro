---
interface Props {
  title: string;
  effectiveDate: string;
  lastUpdated: string;
}

const { title, effectiveDate, lastUpdated } = Astro.props;
---

<section class="hairline-b bg-white py-16 md:py-20">
  <div class="container-content">
    <p class="text-caption font-semibold uppercase tracking-[0.12em] text-mute">Legal</p>
    <h1 class="mt-3 text-balance text-[32px] font-bold tracking-tight text-ink md:text-display-md">{title}</h1>
    <dl class="mt-5 flex flex-wrap gap-x-6 gap-y-1 text-body-sm text-sub">
      <div class="flex gap-2"><dt class="text-mute">시행일</dt><dd class="text-ink">{effectiveDate}</dd></div>
      <div class="flex gap-2"><dt class="text-mute">최종 갱신</dt><dd class="text-ink">{lastUpdated}</dd></div>
    </dl>
  </div>
</section>

<article class="container-content max-w-3xl py-16 md:py-20">
  <div
    class="prose prose-headings:scroll-mt-24 prose-headings:font-bold prose-headings:text-ink
           prose-h2:mt-12 prose-h2:text-heading-lg prose-h2:border-l-2 prose-h2:border-ink prose-h2:pl-3
           prose-h3:mt-8 prose-h3:text-heading-md
           prose-p:leading-relaxed prose-p:text-sub
           prose-li:my-1 prose-li:text-sub
           prose-strong:text-ink
           prose-a:text-ink prose-a:underline prose-a:underline-offset-4 hover:prose-a:text-primary-600
           max-w-none text-[15px] leading-relaxed text-sub"
  >
    <slot />
  </div>
</article>
