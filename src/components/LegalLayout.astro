---
interface Props {
  title: string;
  effectiveDate: string;
  lastUpdated: string;
}

const { title, effectiveDate, lastUpdated } = Astro.props;
---

<section class="border-b border-ink-100 bg-gradient-to-b from-primary-50 to-white py-14 md:py-16">
  <div class="container-content">
    <p class="text-sm font-semibold uppercase tracking-wider text-primary-600">Legal</p>
    <h1 class="mt-3 text-3xl font-extrabold tracking-tight text-ink-900 md:text-4xl">{title}</h1>
    <dl class="mt-4 flex flex-wrap gap-x-6 gap-y-1 text-sm text-ink-700">
      <div class="flex gap-2"><dt class="text-ink-500">시행일</dt><dd>{effectiveDate}</dd></div>
      <div class="flex gap-2"><dt class="text-ink-500">최종 갱신</dt><dd>{lastUpdated}</dd></div>
    </dl>
  </div>
</section>

<article class="container-content max-w-3xl py-14 md:py-16">
  <div
    class="prose prose-headings:scroll-mt-24 prose-headings:font-bold prose-headings:text-ink-900
           prose-h2:mt-12 prose-h2:text-2xl prose-h2:border-l-4 prose-h2:border-primary-600 prose-h2:pl-3
           prose-h3:mt-8 prose-h3:text-lg
           prose-p:leading-relaxed prose-p:text-ink-700
           prose-li:my-1 prose-li:text-ink-700
           prose-strong:text-ink-900
           prose-a:text-primary-600 prose-a:no-underline hover:prose-a:underline
           max-w-none text-[15px] leading-relaxed text-ink-700"
  >
    <slot />
  </div>
</article>
