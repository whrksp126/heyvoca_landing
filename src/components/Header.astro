---
const APPSTORE_URL = 'https://apps.apple.com/app/id6751544570';
const PLAYSTORE_URL = 'https://play.google.com/store/apps/details?id=com.ghmate.heyvoca';
---

<header
  class="sticky top-0 z-50 w-full border-b border-hairline bg-white/90 backdrop-blur-[6px]"
>
  <div class="container-content flex h-16 items-center justify-between">
    <a href="/" aria-label="헤이보카 홈" class="inline-flex items-center">
      <img
        src="/images/logo_h.svg"
        alt="Hey, Voca!"
        width="106"
        height="25"
        class="h-[22px] w-auto select-none"
        loading="eager"
      />
    </a>

    <nav aria-label="주요 메뉴" class="hidden items-center gap-7 md:flex">
      <a href="#how" class="btn-quiet">학습 방식</a>
      <a href="#demo" class="btn-quiet">학습 데모</a>
      <a href="#achievements" class="btn-quiet">업적</a>
      <a href="#download" class="btn-quiet">다운로드</a>
    </nav>

    <div class="flex items-center gap-2">
      <a
        href={APPSTORE_URL}
        target="_blank"
        rel="noopener"
        aria-label="App Store에서 받기"
        class="hidden text-body-sm font-medium text-sub hover:text-ink md:inline-flex"
      >
        iOS
      </a>
      <a
        href={PLAYSTORE_URL}
        target="_blank"
        rel="noopener"
        aria-label="Google Play에서 받기"
        class="hidden text-body-sm font-medium text-sub hover:text-ink md:inline-flex"
      >
        Android
      </a>
      <a href="#download" class="btn-primary !px-5 !py-2 text-body-sm">앱 받기</a>
    </div>
  </div>
</header>
