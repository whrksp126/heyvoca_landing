---
// 통합 섹션: "같은 단어도, 시간이 지나면 다르게 보입니다."
// 좌측 헤딩 + 본문 (이전 MemoryStatesShowcase에서 흡수)
// 우측 5단계 진화 데모 (한 단어가 5단계를 순차 진화)
import MemoryEvolutionDemo from './demo/MemoryEvolutionDemo';
---

<section id="how" class="section bg-surface hairline-t hairline-b" aria-labelledby="solution-h2">
  <div class="container-content grid items-start gap-12 lg:grid-cols-12 lg:gap-20">
    {/* 좌측: 헤딩 + 본문 */}
    <div class="lg:col-span-7 lg:sticky lg:top-24" data-reveal>
      <span class="eyebrow">
        <span class="h-1.5 w-1.5 rounded-full bg-primary-500"></span>
        암기 상태 관리
      </span>
      <h2
        id="solution-h2"
        class="mt-6 text-balance text-[36px] font-bold leading-[1.12] tracking-tight text-ink md:text-display-lg lg:text-display-xl"
      >
        같은 단어도, 시간이<br />
        지나면 다르게 보입니다.
      </h2>
      <p class="mt-6 max-w-prose text-body-lg text-sub text-pretty">
        단어마다 지금 어디쯤에 있는지, 다음에 언제 보여줘야 하는지 헤이보카가 정확히 알고 있습니다.
      </p>
    </div>

    {/* 우측: 5단계 진화 데모 (React island) */}
    <div class="lg:col-span-5" data-reveal>
      <MemoryEvolutionDemo client:visible />
    </div>
  </div>
</section>
