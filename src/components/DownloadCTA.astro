---
const APPSTORE_URL = 'https://apps.apple.com/app/id6751544570';
const PLAYSTORE_URL = 'https://play.google.com/store/apps/details?id=com.ghmate.heyvoca';
---

<section id="download" class="section" aria-labelledby="cta-h2">
  <div class="container-content">
    <div
      class="relative overflow-hidden rounded-[28px] bg-primary-500 px-8 py-16 text-center text-white md:px-12 md:py-24"
      data-reveal
    >
      {/* 미세한 noise + 광택 — 그라데이션 없이 솔리드 핑크 */}
      <div
        aria-hidden="true"
        class="pointer-events-none absolute inset-0 opacity-25"
        style="background-image: radial-gradient(circle at 20% 10%, rgba(255,255,255,0.35) 0, transparent 40%), radial-gradient(circle at 80% 90%, rgba(0,0,0,0.12) 0, transparent 50%);"
      ></div>

      <h2 id="cta-h2" class="relative mx-auto max-w-3xl text-balance text-[32px] font-bold leading-[1.1] tracking-tight md:text-display-lg lg:text-display-xl">
        시작해봅시다.
      </h2>
      <p class="relative mx-auto mt-6 max-w-xl text-body-lg text-white/90">
        무료 · 광고 없음 · 회원가입 1초.<br />
        외운 단어가 사라지지 않는 학습, 지금 바로.
      </p>

      <div class="relative mt-10 flex flex-wrap items-center justify-center gap-3">
        <a
          href={APPSTORE_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex min-w-[200px] items-center gap-3 rounded-2xl bg-ink px-6 py-3.5 text-left transition hover:bg-black focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white"
          aria-label="App Store에서 헤이보카 다운로드"
        >
          <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="text-white">
            <path d="M16.365 1.43c0 1.14-.493 2.27-1.177 3.08-.744.9-1.99 1.57-2.987 1.57-.12-1.17.477-2.31 1.137-3.05.762-.93 2.04-1.6 3.027-1.6zM20.5 17.27c-.55 1.27-.81 1.83-1.51 2.95-.99 1.55-2.38 3.48-4.1 3.49-1.53.02-1.92-1-3.99-.99-2.07.01-2.5 1-4.04.99-1.72-.01-3.04-1.78-4.03-3.33C.83 16.86.45 12.27 2.18 9.65c1.23-1.86 3.18-2.95 4.99-2.95 1.85 0 3.02 1.01 4.55 1.01 1.49 0 2.4-1.01 4.55-1.01 1.62 0 3.34.88 4.56 2.4-4 2.2-3.36 7.92.67 8.18z" />
          </svg>
          <span class="leading-tight text-white">
            <span class="block text-[10px] font-medium uppercase tracking-wider text-white/70">Download on the</span>
            <span class="block text-body-lg font-semibold">App Store</span>
          </span>
        </a>

        <a
          href={PLAYSTORE_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex min-w-[200px] items-center gap-3 rounded-2xl bg-ink px-6 py-3.5 text-left transition hover:bg-black focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white"
          aria-label="Google Play에서 헤이보카 다운로드"
        >
          <svg width="28" height="28" viewBox="0 0 512 512" aria-hidden="true">
            <defs>
              <linearGradient id="gp-1" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="#00C9FF" />
                <stop offset="1" stop-color="#00A1FF" />
              </linearGradient>
              <linearGradient id="gp-2" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0" stop-color="#FFD935" />
                <stop offset="1" stop-color="#FFA000" />
              </linearGradient>
              <linearGradient id="gp-3" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0" stop-color="#FF3A44" />
                <stop offset="1" stop-color="#C31162" />
              </linearGradient>
              <linearGradient id="gp-4" x1="0" y1="0" x2="1" y2="-1">
                <stop offset="0" stop-color="#00A268" />
                <stop offset="1" stop-color="#00F076" />
              </linearGradient>
            </defs>
            <path fill="url(#gp-1)" d="M21,8c-1.84,1.94-2.92,4.95-2.92,8.84v270.32c0,3.89,1.08,6.9,2.92,8.84l1.06,1.04L173.6,156.41v-3.55L22.06,7L21,8z" transform="scale(1.5) translate(-21 -7)" />
            <path fill="url(#gp-2)" d="M224.06,202.1l-50.46-50.69v-3.55l50.47-50.7l1.14,0.65l59.79,33.99c17.07,9.7,17.07,25.6,0,35.31l-59.79,33.99L224.06,202.1z" transform="scale(1.5) translate(-21 -7)" />
            <path fill="url(#gp-3)" d="M225.2,201.46L173.6,149.61L22.06,302.04c5.63,5.96,14.93,6.7,25.4,0.74L225.2,201.46z" transform="scale(1.5) translate(-21 -7)" />
            <path fill="url(#gp-4)" d="M225.2,98.16L47.46,-3.27c-10.48-5.96-19.77-5.22-25.4,0.74L173.6,149.61L225.2,98.16z" transform="scale(1.5) translate(-21 -7)" />
          </svg>
          <span class="leading-tight text-white">
            <span class="block text-[10px] font-medium uppercase tracking-wider text-white/70">GET IT ON</span>
            <span class="block text-body-lg font-semibold">Google Play</span>
          </span>
        </a>
      </div>
    </div>
  </div>
</section>
