---
---

<section id="download" class="scroll-mt-24 py-20 md:py-28">
  <div class="container-content">
    <div class="relative overflow-hidden rounded-[36px] bg-gradient-to-br from-primary-600 via-[#FF88DC] to-[#9B8AFB] px-8 py-16 text-center text-white shadow-[0_30px_60px_-15px_rgba(255,112,212,0.5)] md:px-12 md:py-20">
      <div aria-hidden="true" class="absolute -top-20 -left-20 h-72 w-72 rounded-full bg-white/15 blur-3xl"></div>
      <div aria-hidden="true" class="absolute -bottom-24 -right-16 h-80 w-80 rounded-full bg-white/15 blur-3xl"></div>

      <h2 class="mx-auto max-w-2xl text-3xl font-extrabold leading-tight md:text-4xl">
        오늘부터, 헤이보카와 함께
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-base leading-relaxed text-white/90">
        지금 다운로드하고 첫 단어장을 받아보세요. 무료로 시작합니다.
      </p>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
        <a
          href="https://apps.apple.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex min-w-[180px] items-center gap-3 rounded-2xl bg-black px-6 py-3.5 text-left transition hover:bg-ink-900"
          aria-label="App Store에서 헤이보카 다운로드"
        >
          <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M16.365 1.43c0 1.14-.493 2.27-1.177 3.08-.744.9-1.99 1.57-2.987 1.57-.12-1.17.477-2.31 1.137-3.05.762-.93 2.04-1.6 3.027-1.6zM20.5 17.27c-.55 1.27-.81 1.83-1.51 2.95-.99 1.55-2.38 3.48-4.1 3.49-1.53.02-1.92-1-3.99-.99-2.07.01-2.5 1-4.04.99-1.72-.01-3.04-1.78-4.03-3.33C.83 16.86.45 12.27 2.18 9.65c1.23-1.86 3.18-2.95 4.99-2.95 1.85 0 3.02 1.01 4.55 1.01 1.49 0 2.4-1.01 4.55-1.01 1.62 0 3.34.88 4.56 2.4-4 2.2-3.36 7.92.67 8.18z" />
          </svg>
          <span class="leading-tight">
            <span class="block text-[10px] font-medium uppercase tracking-wider text-white/70">Download on the</span>
            <span class="block text-lg font-semibold">App Store</span>
          </span>
        </a>

        <a
          href="https://play.google.com/store/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex min-w-[180px] items-center gap-3 rounded-2xl bg-black px-6 py-3.5 text-left transition hover:bg-ink-900"
          aria-label="Google Play에서 헤이보카 다운로드"
        >
          <svg width="28" height="28" viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#34D399" d="M3.609 1.814 13.79 12 3.61 22.186a1 1 0 0 1-.61-.92V2.734c0-.387.232-.736.609-.92z" />
            <path fill="#FBBF24" d="m17.95 8.157-3.31 1.91L4.21 0 17.95 8.157z" opacity="0" />
            <path fill="#60A5FA" d="M14.64 14.067 3.99 24l13.86-7.95-3.21-1.983z" />
            <path fill="#F87171" d="M14.64 9.933 17.85 8.05 4.99 0l9.65 9.933z" />
            <path fill="#FBBF24" d="m20.16 11.13-3.21 1.875-3.21-1.939 3.21-1.972 3.21 1.875a1.245 1.245 0 0 1 0 2.16z" />
          </svg>
          <span class="leading-tight">
            <span class="block text-[10px] font-medium uppercase tracking-wider text-white/70">GET IT ON</span>
            <span class="block text-lg font-semibold">Google Play</span>
          </span>
        </a>
      </div>

      <p class="mt-8 text-xs text-white/70">* 정식 출시 전 베타 단계일 수 있습니다.</p>
    </div>
  </div>
</section>
