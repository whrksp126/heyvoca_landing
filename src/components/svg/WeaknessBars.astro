---
const bars = [
  { label: '객관식 4지선다', value: 92, weak: false },
  { label: '빈칸 채우기', value: 67, weak: true },
  { label: '듣기 단답', value: 81, weak: false },
  { label: '동의어 매칭', value: 88, weak: false },
];
---

<div class="rounded-card border border-hairline bg-white p-6 md:p-8">
  <div class="mb-6 flex items-center justify-between">
    <p class="text-caption font-semibold uppercase tracking-[0.12em] text-mute">유형별 정답률</p>
    <span class="inline-flex items-center gap-1.5 rounded-full bg-primary-100 px-2.5 py-1 text-[11px] font-semibold text-primary-700">
      <span class="h-1.5 w-1.5 rounded-full bg-primary-500"></span>
      약점 감지됨
    </span>
  </div>

  <ul class="space-y-4">
    {bars.map((b) => (
      <li>
        <div class="flex items-center justify-between text-body-sm">
          <span class={`font-medium ${b.weak ? 'text-ink' : 'text-sub'}`}>{b.label}</span>
          <span class={`tabular-nums ${b.weak ? 'font-semibold text-primary-700' : 'text-sub'}`}>{b.value}%</span>
        </div>
        <div class="mt-2 h-2 w-full overflow-hidden rounded-full bg-surface">
          <div
            class={`h-full rounded-full transition-all duration-700 ${b.weak ? 'bg-primary-500' : 'bg-ink'}`}
            style={`width: ${b.value}%;`}
          ></div>
        </div>
        {b.weak && (
          <p class="mt-2 text-caption text-primary-700">
            지난 30회 평균보다 14%p 낮음 — 다음 학습에서 자동 강화
          </p>
        )}
      </li>
    ))}
  </ul>
</div>
