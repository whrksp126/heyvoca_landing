---
// 단순화된 망각 곡선. Days [1, 3, 7, 30]에 점이 찍히고 곡선이 하강.
// 100% → 약 70% → 50% → 35% → 20% (저장률 시각화)
---

<svg
  viewBox="0 0 480 280"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="시간이 지남에 따라 기억 저장률이 떨어지는 망각 곡선"
  class="h-auto w-full"
>
  {/* 배경 */}
  <rect x="0" y="0" width="480" height="280" fill="transparent" />

  {/* 가로축 그리드 */}
  <g stroke="#ECECEC" stroke-width="1">
    <line x1="40" y1="40" x2="460" y2="40" />
    <line x1="40" y1="100" x2="460" y2="100" />
    <line x1="40" y1="160" x2="460" y2="160" />
    <line x1="40" y1="220" x2="460" y2="220" />
  </g>

  {/* 축 라벨 (Y) */}
  <g font-family="Pretendard, sans-serif" font-size="11" fill="#8A8A8A">
    <text x="32" y="44" text-anchor="end">100%</text>
    <text x="32" y="104" text-anchor="end">75%</text>
    <text x="32" y="164" text-anchor="end">50%</text>
    <text x="32" y="224" text-anchor="end">25%</text>
  </g>

  {/* 축 라벨 (X) */}
  <g font-family="Pretendard, sans-serif" font-size="11" fill="#8A8A8A">
    <text x="80" y="248" text-anchor="middle">Day 1</text>
    <text x="180" y="248" text-anchor="middle">Day 3</text>
    <text x="290" y="248" text-anchor="middle">Day 7</text>
    <text x="430" y="248" text-anchor="middle">Day 30</text>
  </g>

  {/* 곡선 (감소) */}
  <path
    d="M 80 50 C 130 90, 150 130, 180 145 S 250 195, 290 200 S 380 218, 430 222"
    fill="none"
    stroke="#0A0A0A"
    stroke-width="2.2"
    stroke-linecap="round"
  />

  {/* 점 + 핑크 강조점 (Day 7: 위험 구간) */}
  <g>
    <circle cx="80" cy="50" r="5" fill="#0A0A0A" />
    <circle cx="180" cy="145" r="5" fill="#0A0A0A" />
    <circle cx="290" cy="200" r="6" fill="#FF70D4" />
    <circle cx="290" cy="200" r="11" fill="none" stroke="#FF70D4" stroke-opacity="0.35" stroke-width="2" />
    <circle cx="430" cy="222" r="5" fill="#0A0A0A" />
  </g>

  {/* Day 7 캡션 */}
  <g font-family="Pretendard, sans-serif">
    <line x1="290" y1="190" x2="290" y2="80" stroke="#FF70D4" stroke-width="1" stroke-dasharray="3 4" />
    <text x="290" y="72" text-anchor="middle" font-size="12" fill="#0A0A0A" font-weight="600">일주일 후엔 50%만</text>
    <text x="290" y="88" text-anchor="middle" font-size="11" fill="#5C5C5C">바로 이 시점, 다시 만나야 합니다</text>
  </g>
</svg>
